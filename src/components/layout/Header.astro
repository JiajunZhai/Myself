---
import ThemeToggle from '../ui/ThemeToggle.astro';
import SearchModal from '../ui/SearchModal.astro';
import LanguageToggle from '../ui/LanguageToggle.astro';
import { siteConfig } from '../../site.config';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const isDev = import.meta.env.DEV;
---
<header class="py-6 border-b border-gray-200 dark:border-gray-800">
  <div class="max-w-4xl mx-auto px-4 flex items-center justify-between">
    <a href={translatePath('/')} class="text-xl font-bold tracking-tight shrink-0">
      <span class="text-accent">&lt;</span> {siteConfig.title} <span class="text-accent">/&gt;</span>
    </a>
    <nav class="flex gap-4 md:gap-6 items-center font-medium">
      <button onclick="document.dispatchEvent(new KeyboardEvent('keydown', {key: 'k', metaKey: true}))" class="hidden md:flex items-center gap-2 px-3 py-1.5 text-sm text-gray-500 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-lg transition-colors border border-gray-200 dark:border-gray-700">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        <span>{t('nav.search')}</span>
        <kbd class="font-mono text-xs ml-2 opacity-70">Cmd K</kbd>
      </button>
      <a href={translatePath('/')} class="hover:text-accent transition-colors">{t('nav.home')}</a>
      <a href={translatePath('/blog')} class="hover:text-accent transition-colors">{t('nav.blog')}</a>
      <a href={translatePath('/projects')} class="hover:text-accent transition-colors">{t('nav.projects')}</a>
      
      <div class="flex items-center gap-2 border-l border-gray-200 dark:border-gray-700 pl-4 ml-2">
        {isDev && (
          <a href="/keystatic" class="text-gray-500 hover:text-accent transition-colors flex items-center justify-center p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800" title="Keystatic CMS (Dev Only)">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3M13 15h4M4 4h16v16H4z"/></svg>
          </a>
        )}
        <LanguageToggle />
        <ThemeToggle />
      </div>
    </nav>
  </div>
  <SearchModal />
</header>
