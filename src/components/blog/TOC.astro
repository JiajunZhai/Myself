---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth > 1 && h.depth < 4);
---

{filteredHeadings.length > 0 && (
  <nav class="toc-container sticky top-24 max-h-[calc(100vh-8rem)] overflow-auto hidden lg:block">
    <h3 class="text-sm font-bold text-gray-900 dark:text-gray-100 uppercase tracking-wider mb-4 border-b border-gray-200 dark:border-gray-800 pb-2">On this page</h3>
    <ul class="flex flex-col gap-2 relative">
      <div id="toc-indicator" class="absolute left-0 w-0.5 bg-accent transition-all duration-300" style="top: 0; height: 0;"></div>
      {filteredHeadings.map((heading) => (
        <li class="relative border-l-2 border-transparent">
          <a
            href={`#${heading.slug}`}
            class={`toc-link block py-1 text-sm text-gray-500 hover:text-accent transition-colors
              ${heading.depth === 3 ? 'pl-6' : 'pl-3'}`}
            data-slug={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  document.addEventListener('astro:page-load', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            document.querySelectorAll('.toc-link').forEach((link) => {
              link.classList.remove('text-accent', 'font-medium');
              if (link.getAttribute('data-slug') === entry.target.id) {
                link.classList.add('text-accent', 'font-medium');
                
                // Update indicator
                const indicator = document.getElementById('toc-indicator');
                if (indicator) {
                  const linkEl = link as HTMLElement;
                  indicator.style.top = `${linkEl.offsetTop}px`;
                  indicator.style.height = `${linkEl.offsetHeight}px`;
                }
              }
            });
          }
        });
      },
      { rootMargin: '-10% 0px -80% 0px' }
    );

    document.querySelectorAll('h2, h3').forEach((heading) => {
      observer.observe(heading);
    });
  });
</script>
