---
interface Props {
  size?: number;
  className?: string;
}
const { size = 40, className = "" } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class={className}>
  <!-- 底层柔和圆角矩形 -->
  <rect width="40" height="40" rx="12" fill="currentColor" class="text-slate-100 dark:text-slate-800"/>
  
  <!-- 猫咪主体 (极简剪影) -->
  <path d="M10 24C10 18.4772 14.4772 14 20 14C25.5228 14 30 18.4772 30 24V32H10V24Z" fill="currentColor" class="text-slate-800 dark:text-slate-200"/>
  
  <!-- 耳朵 (几何三角形) -->
  <path d="M12 15L16 6L21 13" fill="currentColor" class="text-slate-800 dark:text-slate-200"/>
  <path d="M28 15L24 6L19 13" fill="currentColor" class="text-slate-800 dark:text-slate-200"/>
  
  <!-- 眼睛 (两条极简横线，展现“冷淡/厌世”的可爱感) -->
  <rect x="15" y="20" width="3" height="1.5" rx="0.75" fill="white" class="dark:fill-slate-800"/>
  <rect x="22" y="20" width="3" height="1.5" rx="0.75" fill="white" class="dark:fill-slate-800"/>
  
  <!-- 动态的小星星 (点睛之笔) -->
  <path d="M30 8L31 10.5L33.5 11.5L31 12.5L30 15L29 12.5L26.5 11.5L29 10.5L30 8Z" fill="#FACC15">
    <animate attributeName="opacity" values="1;0.4;1" dur="3s" repeatCount="indefinite" />
  </path>
</svg>
