---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="py-24 border-t border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-[#09090b] relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-accent/5 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-purple-500/5 rounded-full blur-[80px] translate-y-1/3 -translate-x-1/4 pointer-events-none"></div>

  <div class="max-w-4xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-12 relative z-10">
    <div class="flex-1">
      <h2 class="text-4xl md:text-5xl font-black tracking-tight mb-6 leading-tight">
        {t('philosophy.quote')}
      </h2>
      <p class="text-gray-500 dark:text-gray-400 text-lg md:text-xl font-medium max-w-lg mb-8">
        {t('philosophy.sub')}
      </p>
      <div class="w-20 h-1 bg-accent rounded-full"></div>
    </div>

    <!-- RSS Subscription Box -->
    <div class="w-full md:w-auto shrink-0 flex flex-col items-center p-8 rounded-3xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 shadow-xl group hover:border-accent/40 transition-colors">
      <div class="w-16 h-16 rounded-2xl bg-orange-100 dark:bg-orange-900/30 text-orange-500 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" /></svg>
      </div>
      <a href="/rss.xml" class="px-8 py-3 bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-bold rounded-xl hover:-translate-y-1 transition-transform mb-3 shadow-[0_0_20px_rgba(0,0,0,0.1)] dark:shadow-[0_0_20px_rgba(255,255,255,0.1)]">
        {t('philosophy.rss')}
      </a>
      <span class="text-xs text-gray-500 font-mono flex items-center gap-1">
        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
        Live Signal
      </span>
    </div>
  </div>
</section>
