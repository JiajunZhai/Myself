---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<div class="terminal-container rounded-xl overflow-hidden border border-gray-700/50 bg-[#0d1117]/90 backdrop-blur-md shadow-2xl font-mono text-sm w-full mx-auto relative group">
  <!-- Window Header -->
  <div class="flex items-center px-4 py-3 bg-[#161b22]/90 border-b border-gray-700/50">
    <div class="flex gap-2">
      <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
      <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
    </div>
    <div class="mx-auto text-gray-400 text-xs flex items-center gap-2">
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M4 4h16v16H4V4z" /></svg>
      guest@kian-machine:~
    </div>
  </div>

  <!-- Terminal Body -->
  <div class="p-4 h-[250px] overflow-y-auto text-gray-300 custom-scrollbar" id="terminal-body" onclick="document.getElementById('terminal-input').focus()">
    <div class="mb-2 text-[#38bdf8]">Welcome to Kian OS v1.0.4. Type 'help' to see available commands.</div>
    
    <div id="terminal-output"></div>
    
    <div class="flex items-center mt-2 text-green-400">
      <span class="mr-2">guest@kian:~$</span>
      <input type="text" id="terminal-input" class="bg-transparent border-none outline-none flex-1 text-gray-300 font-mono caret-white" autocomplete="off" spellcheck="false" />
    </div>
  </div>
</div>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #30363d;
    border-radius: 4px;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const input = document.getElementById('terminal-input') as HTMLInputElement;
    const output = document.getElementById('terminal-output');
    
    if (!input || !output) return;

    const commands: Record<string, string | (() => string)> = {
      help: () => `
        <div class="text-gray-400 grid grid-cols-[100px_1fr] gap-2 mt-2 mb-4">
          <span class="text-green-300">whoami</span><span>Display current entity information</span>
          <span class="text-green-300">skills</span><span>List loaded combat/dev modules</span>
          <span class="text-green-300">repo</span><span>Access source code coordinates</span>
          <span class="text-green-300">clear</span><span>Wipe terminal buffer</span>
          <span class="text-green-300">sudo</span><span>Escalate privileges</span>
        </div>
      `,
      whoami: () => `<div class="text-yellow-300 mt-2 mb-4">Kian / Developer & Writer<br/>Location: Earth<br/>Status: Translating caffeine into code.</div>`,
      skills: () => `<div class="text-blue-300 mt-2 mb-4">[ TypeScript, React, Astro, Node.js, Python, TailwindCSS ] => Loading 100%</div>`,
      repo: () => {
        setTimeout(() => window.open('https://github.com/JiajunZhai', '_blank'), 500);
        return `<div class="text-gray-400 mt-2 mb-4">Establishing secure connection to GitHub...</div>`;
      },
      sudo: () => `<div class="text-red-400 mt-2 mb-4">Permission denied. This incident will be reported.</div>`
    };

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const cmd = input.value.trim().toLowerCase();
        
        // Echo command
        const echo = document.createElement('div');
        echo.className = 'text-green-400 mt-2';
        echo.innerHTML = `<span class="mr-2">guest@kian:~$</span><span class="text-gray-300">${cmd}</span>`;
        output.appendChild(echo);

        // Process command
        if (cmd === 'clear') {
          output.innerHTML = '';
        } else if (cmd !== '') {
          const response = document.createElement('div');
          if (commands[cmd]) {
            response.innerHTML = typeof commands[cmd] === 'function' ? (commands[cmd] as Function)() : commands[cmd];
          } else {
            response.innerHTML = `<div class="text-red-400 mt-1 mb-3">bash: ${cmd}: command not found</div>`;
          }
          output.appendChild(response);
        }

        input.value = '';
        document.getElementById('terminal-body')?.scrollTo(0, document.getElementById('terminal-body')!.scrollHeight);
      }
    });
  });
</script>
