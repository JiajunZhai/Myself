---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Using high-quality unsplash placeholders for the aesthetic
const galleryImages = [
  { url: 'https://images.unsplash.com/photo-1555099962-4199c345e5dd?q=80&w=800&auto=format&fit=crop', alt: 'Coding Setup', span: 'col-span-2 row-span-2' },
  { url: 'https://images.unsplash.com/photo-1614624532983-4ce03382d63d?q=80&w=800&auto=format&fit=crop', alt: 'Mechanical Keyboard', span: 'col-span-1 row-span-1' },
  { url: 'https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=800&auto=format&fit=crop', alt: 'Hardware Circuit', span: 'col-span-1 row-span-1' },
  { url: 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=800&auto=format&fit=crop', alt: 'Late night coding', span: 'col-span-2 row-span-1' },
];
---
<section class="py-16 md:py-24 border-t border-gray-200 dark:border-gray-800">
  <div class="max-w-4xl mx-auto px-4">
    <div class="mb-12 flex justify-between items-end">
      <div>
        <h2 class="text-3xl font-black tracking-tight mb-2 flex items-center gap-2">
          <span class="text-accent">📸</span> {t('gallery.title')}
        </h2>
        <p class="text-gray-500 dark:text-gray-400 font-mono text-sm">{t('gallery.desc')}</p>
      </div>
    </div>

    <!-- CSS Grid Masonry approximation -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 auto-rows-[150px]">
      {galleryImages.map((image) => (
        <div class={`relative rounded-2xl overflow-hidden group ${image.span} border border-gray-200 dark:border-gray-800 bg-gray-100 dark:bg-gray-900`}>
          <!-- Glitch overlay effect on hover -->
          <div class="absolute inset-0 bg-accent/20 z-10 opacity-0 group-hover:opacity-100 mix-blend-color-dodge transition-opacity duration-500 pointer-events-none"></div>
          
          <img 
            src={image.url} 
            alt={image.alt} 
            class="w-full h-full object-cover filter grayscale-[50%] group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700 ease-out"
            loading="lazy"
          />
          
          <!-- Image caption / tag -->
          <div class="absolute bottom-4 left-4 z-20 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
            <span class="px-3 py-1 bg-black/60 backdrop-blur-md text-white text-xs font-mono rounded-full font-medium">
              {image.alt}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
