---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section class="py-16 md:py-24 border-t border-gray-200 dark:border-gray-800">
  <div class="max-w-4xl mx-auto px-4">
    <div class="mb-12">
      <h2 class="text-3xl font-black tracking-tight mb-2 flex items-center gap-2">
        <span class="text-accent">●</span> {t('now.title')}
      </h2>
      <p class="text-gray-500 dark:text-gray-400 font-mono text-sm">{t('now.desc')}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Build Item -->
      <div class="p-6 rounded-2xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 hover:-translate-y-1 transition-transform shadow-sm hover:shadow-md group">
        <div class="w-10 h-10 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-blue-500 mb-4 group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
        </div>
        <h3 class="font-bold text-lg mb-1">{t('now.building')}</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{t('now.building.desc')}</p>
      </div>

      <!-- Reading Item -->
      <div class="p-6 rounded-2xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 hover:-translate-y-1 transition-transform shadow-sm hover:shadow-md group">
        <div class="w-10 h-10 rounded-full bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center text-emerald-500 mb-4 group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
        </div>
        <h3 class="font-bold text-lg mb-1">{t('now.reading')}</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{t('now.reading.desc')}</p>
      </div>

      <!-- Obsessed Item -->
      <div class="p-6 rounded-2xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 hover:-translate-y-1 transition-transform shadow-sm hover:shadow-md group">
        <div class="w-10 h-10 rounded-full bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-purple-500 mb-4 group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
        </div>
        <h3 class="font-bold text-lg mb-1">{t('now.playing')}</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{t('now.playing.desc')}</p>
      </div>
    </div>
  </div>
</section>
