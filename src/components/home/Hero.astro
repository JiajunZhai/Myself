---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';
import Terminal from './Terminal.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---
<section class="py-24 md:py-36 min-h-[75vh] flex items-center justify-center">
  <div class="max-w-6xl mx-auto px-4 flex flex-col lg:flex-row gap-12 items-center w-full">
    <div class="flex-1 flex flex-col gap-6 w-full">
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight">
        {t('hero.greeting')} <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-[#22c55e]">KIAN</span>.
      </h1>
      
      <div class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 font-medium font-mono h-8 overflow-hidden relative">
        <span class="inline-block whitespace-nowrap border-r-2 border-accent pr-1 animate-typing overflow-hidden w-0" style="animation: typing 3s steps(40, end) forwards, blink .75s step-end infinite;">
          {t('hero.role')}
        </span>
      </div>

      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-xl mt-4">
        {t('hero.desc')}
      </p>

      <div class="flex gap-4 mt-8">
        <a href={translatePath('/blog')} class="px-6 py-3 bg-gray-900 text-white dark:bg-white dark:text-gray-900 font-bold rounded-lg hover:-translate-y-1 hover:shadow-xl transition-all">
          {t('hero.cta.blog')}
        </a>
        <a href="https://github.com/JiajunZhai" target="_blank" rel="noopener noreferrer" class="px-6 py-3 border border-gray-300 dark:border-gray-700 font-bold rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 hover:-translate-y-1 transition-all">
          GitHub
        </a>
      </div>
    </div>

    <div class="flex-1 w-full relative z-10 hidden md:block group perspective-[1000px]">
      <div class="absolute -inset-1 bg-gradient-to-r from-accent to-purple-600 rounded-xl blur opacity-25 group-hover:opacity-60 transition duration-1000 group-hover:duration-200 animate-pulse"></div>
      <div class="transform rotate-y-[-5deg] rotate-x-[5deg] hover:rotate-y-0 hover:rotate-x-0 transition-transform duration-500">
        <Terminal />
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes typing {
    from { width: 0; }
    to { width: 100%; }
  }
  @keyframes blink {
    from, to { border-color: transparent; }
    50% { border-color: var(--color-accent); }
  }
</style>
