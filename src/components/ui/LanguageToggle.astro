---
import { languages } from '../../i18n/ui';
import { getLangFromUrl, useTranslatedPath } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL;
let pathname = Astro.url.pathname;

// Strip out Github Pages Base URL to resolve relative internal path
if (base && base !== '/' && pathname.startsWith(base)) {
  pathname = pathname.substring(base.length);
}
if (!pathname.startsWith('/')) {
  pathname = '/' + pathname;
}

// Strip out current language prefix
const strippedPath = pathname.replace(/^\/(en|zh)/, ''); 

const targetLang = lang === 'en' ? 'zh' : 'en';
const translatePath = useTranslatedPath(targetLang);
const targetPath = translatePath(strippedPath);

const label = lang === 'en' ? 'ZH' : 'EN';
---

<a href={targetPath} class="px-2 py-1 text-xs font-bold font-mono border border-gray-200 dark:border-gray-800 rounded-md text-gray-500 hover:text-accent dark:hover:text-accent hover:border-accent dark:hover:border-accent transition-colors">
  {label}
</a>
