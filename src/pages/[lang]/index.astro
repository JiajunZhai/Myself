---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Hero from '../../components/home/Hero.astro';
import Marquee from '../../components/home/Marquee.astro';
import BentoGrid from '../../components/home/BentoGrid.astro';
import RecentPosts from '../../components/home/RecentPosts.astro';
import NowStatus from '../../components/home/NowStatus.astro';
import LifeGallery from '../../components/home/LifeGallery.astro';
import Philosophy from '../../components/home/Philosophy.astro';
import { siteConfig } from '../../site.config';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

// 获取所有静态数据
const allSkills = await getCollection('skills');
const socialLinks = await getCollection('socials');
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
	<Header />
	<main class="flex-grow">
		<Hero />
		<Marquee />
		<NowStatus />
		<BentoGrid skills={allSkills} socials={socialLinks} />
		<LifeGallery />
		<RecentPosts />
		<Philosophy />
	</main>
	<Footer />
</BaseLayout>
