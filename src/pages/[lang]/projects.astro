---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const pageLang = getLangFromUrl(Astro.url);
const t = useTranslations(pageLang);

import { getTopProjects } from '../../utils/github';
let projects = await getTopProjects(6);

// Fallback if API fails or rate limited
if (projects.length === 0) {
  projects = [
    {
      name: "Astro Geek Garden",
      description: "A blazingly fast portfolio and blog template with a true cyberpunk aesthetic.",
      stars: 128,
      language: "Astro",
      url: "https://github.com/JiajunZhai"
    },
    {
      name: "React Bento Grid",
      description: "A lightweight, 3D physics-based bento grid layout engine for React applications.",
      stars: 84,
      language: "TypeScript",
      url: "https://github.com/JiajunZhai"
    },
    {
      name: "Terminal Emulator UI",
      description: "A completely responsive web-based terminal interface mimicking Linux shell interactions.",
      stars: 42,
      language: "CSS",
      url: "https://github.com/JiajunZhai"
    }
  ];
}

---

<BaseLayout title={t('projects.title')}>
  <Header />
  <main class="flex-grow py-12 max-w-4xl mx-auto px-4 w-full">
    <h1 class="text-4xl font-bold mb-4">{t('projects.title')}</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-12">
      {t('projects.desc')}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map(project => (
        <a href={project.url} target="_blank" rel="noopener noreferrer" class="block p-6 rounded-2xl border border-gray-200 dark:border-gray-800 hover:border-accent dark:hover:border-accent hover:shadow-lg transition-all group bg-white dark:bg-gray-900">
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-xl font-bold group-hover:text-accent transition-colors flex items-center gap-2">
              <svg class="w-5 h-5 text-gray-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              {project.name}
            </h3>
            <div class="flex items-center text-sm text-gray-500 gap-1 bg-gray-100 dark:bg-gray-800 px-2 py-1 rounded-full">
              <svg class="w-4 h-4 text-yellow-500" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              {project.stars}
            </div>
          </div>
          <p class="text-gray-600 dark:text-gray-400 mb-6 text-sm">{project.description}</p>
          <div class="flex items-center text-sm font-medium text-gray-500">
            <span class="w-3 h-3 rounded-full mr-2 bg-accent"></span>
            {project.language}
          </div>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>
