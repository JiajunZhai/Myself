---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404: Lost in the Void">
  <main class="w-full h-screen bg-white dark:bg-[#09090b] flex flex-col items-center justify-center font-sans">
    
    <div class="relative group cursor-pointer z-10">
      
      <!-- 猫咪 (隐藏在箱子里，悬停时探头) - 改为 z-10 且写在纸箱前面 -->
      <div class="absolute top-10 left-1/2 -translate-x-1/2 z-10 transition-all duration-500 ease-out group-hover:-translate-y-20">
        <svg width="100" height="100" viewBox="0 0 100 100">
           <!-- 猫头剪影 -->
           <path d="M20 50C20 30 35 20 50 20C65 20 80 30 80 50V80H20V50Z" fill="currentColor" class="text-slate-800 dark:text-slate-400"/>
           <!-- 耳朵 -->
           <path d="M25 25L35 10L45 22" fill="currentColor" class="text-slate-800 dark:text-slate-400"/>
           <path d="M75 25L65 10L55 22" fill="currentColor" class="text-slate-800 dark:text-slate-400"/>
           <!-- 发光的眼睛 -->
           <circle cx="40" cy="45" r="3" fill="#22c55e" class="animate-pulse" />
           <circle cx="60" cy="45" r="3" fill="#22c55e" class="animate-pulse" />
        </svg>
      </div>

      <!-- 纸箱插画 (极简线条) - 盖在猫咪前面 z-20 -->
      <div class="relative z-20">
        <svg width="240" height="160" viewBox="0 0 240 160" fill="none">
          <!-- 纸箱主体 -->
          <path d="M20 60H220V140C220 151.046 211.046 160 200 160H40C28.9543 160 20 151.046 20 140V60Z" fill="currentColor" class="text-slate-100 dark:text-slate-800"/>
          <!-- 纸箱盖子 -->
          <path d="M20 60L10 30H110L120 60" stroke="currentColor" stroke-width="4" class="text-slate-200 dark:text-slate-700"/>
          <path d="M220 60L230 30H130L120 60" stroke="currentColor" stroke-width="4" class="text-slate-200 dark:text-slate-700"/>
          <!-- 胶带/装饰 -->
          <rect x="100" y="90" width="40" height="20" rx="2" fill="currentColor" class="text-slate-300 dark:text-slate-600"/>
        </svg>
      </div>
    </div>

    <!-- 文字说明 -->
    <div class="mt-12 text-center">
      <h1 class="text-5xl font-black text-slate-900 dark:text-white mb-4 tracking-tighter">
        OUT OF BOUNDS
      </h1>
      <p class="text-slate-500 dark:text-slate-400 font-mono mb-8 uppercase tracking-widest text-sm">
        > status: cat_is_in_the_box
      </p>
      
      <a href="/" class="group relative inline-flex items-center gap-2 px-8 py-3 bg-slate-900 dark:bg-white text-white dark:text-black font-bold rounded-full overflow-hidden transition-all hover:pr-12">
        <span class="relative z-10">BACK TO SAFETY</span>
        <span class="absolute right-4 opacity-0 transition-all group-hover:opacity-100 group-hover:translate-x-0 -translate-x-4">→</span>
      </a>
    </div>

  </main>
</BaseLayout>

<style>
  /* 简单的呼吸效果 */
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.2); }
  }
</style>
